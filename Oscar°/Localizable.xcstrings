    "Enable notifications to receive rain alerts and weather alerts. Your approximate location will be stored on an Oscar server for this." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere Mitteilungen, um Regenwarnungen und Wetterwarnungen zu erhalten. Dein ungefährer Standort wird dazu auf einem Oscar-Server gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable notifications to receive rain alerts and weather alerts. Your approximate location will be stored on an Oscar server for this."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yağmur uyarıları ve hava durumu uyarıları almak için bildirimleri etkinleştirin. Bunun için yaklaşık konumunuz bir Oscar sunucusunda saklanacaktır."
          }
        }
      }
    },
