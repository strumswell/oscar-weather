    "Standardmäßig wählt Oscar automatisch das beste Wettermodell. Fortgeschrittene Nutzer können ein bestimmtes Modell erzwingen." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig wählt Oscar automatisch das beste Wettermodell. Fortgeschrittene Nutzer können ein bestimmtes Modell erzwingen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By default, Oscar automatically picks the best weather model. Advanced users can force a specific model."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oscar varsayılan olarak en iyi hava durumu modelini otomatik seçer. İleri düzey kullanıcılar belirli bir modeli zorlayabilir."
          }
        }
      }
    },
    "Standardmäßig wählt Oscar für jeden Ort automatisch das beste Modell und kombiniert mehrere Wetterdienste. Empfohlen für die meisten Nutzer." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig wählt Oscar für jeden Ort automatisch das beste Modell und kombiniert mehrere Wetterdienste. Empfohlen für die meisten Nutzer."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By default, Oscar automatically picks the best model for each location and combines several weather services. Recommended for most users."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oscar varsayılan olarak her konum için en iyi modeli otomatik seçer ve birden fazla hava durumu servisini birleştirir. Çoğu kullanıcı için önerilir."
          }
        }
      }
    },
