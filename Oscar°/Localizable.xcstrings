    "Notifications are turned off in Oscar. Turn them on to receive rain alerts and weather alerts for your current location." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitteilungen sind in Oscar ausgeschaltet. Aktiviere sie, um Regenwarnungen und Wetterwarnungen für deinen aktuellen Ort zu erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications are turned off in Oscar. Turn them on to receive rain alerts and weather alerts for your current location."
