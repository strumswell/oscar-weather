            "state" : "translated",
            "value" : "Yağmur uyarıları ve hava durumu uyarıları şu anda beta aşamasındadır ve yalnızca Orta Avrupa için kullanılabilir."
          }
        }
      }
    },
    "RainViewer stellt diverse Kartenlayer bereit. Darunter fallen unter anderem das globale Regenradar und Satellitenbilder." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RainViewer provides various map layers. These include, among others, the global rain radar and satellite images."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RainViewer çeşitli harita katmanları sunmaktadır. Bunlar arasında küresel yağmur radarı ve uydu görüntüleri de bulunmaktadır."
          }
        }
      }
    },
    "Rauch driftet leicht, Windfahnen bleiben ruhig." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
