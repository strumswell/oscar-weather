    "Aktiviere Regenwarnungen (Beta) für Mitteleuropa, um Mitteilungen bei bevorstehendem Regen zu erhalten. Dein ungefährer Standort wird dazu auf einem Oscar-Server gespeichert." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere Regenwarnungen (Beta) für Mitteleuropa, um Mitteilungen bei bevorstehendem Regen zu erhalten. Dein ungefährer Standort wird dazu auf einem Oscar-Server gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable rain alerts (Beta) for Central Europe to receive notifications about upcoming rain. Your approximate location will be stored on an Oscar server for this."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yaklaşan yağmur hakkında bildirim almak için Orta Avrupa yağmur uyarılarını (Beta) etkinleştirin. Bunun için yaklaşık konumunuz bir Oscar sunucusunda saklanır."
          }
        }
      }
    },
