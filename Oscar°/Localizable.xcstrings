    "PM10 stammt oft aus Straßenstaub, Baustellen und Landwirtschaft. Die Partikel reizen Augen und Atemwege und können Beschwerden bei empfindlichen Personen verstärken." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PM10 stammt oft aus Straßenstaub, Baustellen und Landwirtschaft. Die Partikel reizen Augen und Atemwege und können Beschwerden bei empfindlichen Personen verstärken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PM10 often comes from road dust, construction sites, and agriculture. These particles can irritate the eyes and airways and worsen symptoms in sensitive people."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PM10 çoğu zaman yol tozu, inşaat alanları ve tarımdan kaynaklanır. Bu parçacıklar gözleri ve solunum yollarını tahriş edebilir ve hassas kişilerde şikayetleri artırabilir."
          }
        }
      }
    },
    "PM2.5 entsteht vor allem durch Verkehr, Holzfeuer und Industrie. Die feinen Partikel dringen tief in die Lunge ein und belasten Atemwege und Herz-Kreislauf-System." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PM2.5 entsteht vor allem durch Verkehr, Holzfeuer und Industrie. Die feinen Partikel dringen tief in die Lunge ein und belasten Atemwege und Herz-Kreislauf-System."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PM2.5 mainly comes from traffic, wood burning, and industry. These fine particles can penetrate deep into the lungs and strain the airways and cardiovascular system."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PM2.5 çoğunlukla trafik, odun yakımı ve sanayiden kaynaklanır. Bu ince parçacıklar akciğerlerin derinliklerine ulaşabilir ve solunum yolları ile kalp damar sistemini zorlayabilir."
          }
        }
      }
    },
    "Schadstoffe jetzt" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schadstoffe jetzt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pollutants now"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şu anki kirleticiler"
          }
        }
      }
    },
    "Schlecht" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schlecht"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poor"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kötü"
          }
        }
      }
    },
    "Schwefeldioxid entsteht vor allem bei der Verbrennung schwefelhaltiger Brennstoffe in Industrie und Energieerzeugung. Es reizt die Atemwege und belastet besonders Menschen mit Asthma." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schwefeldioxid entsteht vor allem bei der Verbrennung schwefelhaltiger Brennstoffe in Industrie und Energieerzeugung. Es reizt die Atemwege und belastet besonders Menschen mit Asthma."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sulfur dioxide mainly results from burning sulfur-containing fuels in industry and power generation. It irritates the airways and is especially stressful for people with asthma."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kükürt dioksit çoğunlukla sanayi ve enerji üretiminde kükürt içeren yakıtların yakılmasıyla oluşur. Solunum yollarını tahriş eder ve özellikle astımı olan kişiler için yük oluşturur."
          }
        }
      }
    },
    "Sehr hohe gesundheitliche Gefährdung, Schutzmaßnahmen sind unbedingt erforderlich." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sehr hohe gesundheitliche Gefährdung, Schutzmaßnahmen sind unbedingt erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Very high health risk, protective measures are essential."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çok yüksek sağlık riski, korunma önlemleri mutlaka gereklidir."
          }
        }
      }
    },
    "Sehr schlecht" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sehr schlecht"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Very poor"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çok kötü"
          }
        }
      }
    },
    "Stickstoffdioxid entsteht vor allem bei Verbrennungsprozessen im Straßenverkehr und in Heizungen. Es reizt die Atemwege und kann Asthma sowie andere Lungenerkrankungen verschlimmern." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stickstoffdioxid entsteht vor allem bei Verbrennungsprozessen im Straßenverkehr und in Heizungen. Es reizt die Atemwege und kann Asthma sowie andere Lungenerkrankungen verschlimmern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nitrogen dioxide is mainly produced by combustion in road traffic and heating systems. It irritates the airways and can worsen asthma and other lung diseases."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Azot dioksit çoğunlukla karayolu trafiği ve ısıtma sistemlerindeki yanma süreçlerinden kaynaklanır. Solunum yollarını tahriş eder ve astım ile diğer akciğer hastalıklarını kötüleştirebilir."
          }
        }
      }
    },
