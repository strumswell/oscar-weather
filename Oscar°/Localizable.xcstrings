    "Rain alerts and weather alerts are currently in beta and only available for Central Europe." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regenwarnungen und Wetterwarnungen sind derzeit in der Beta und nur für Mitteleuropa verfügbar."
          }
        },
        "en" : {
