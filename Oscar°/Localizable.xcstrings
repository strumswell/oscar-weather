    },
    "Datengrundlage ist die ERA5-Reanalyse: Wettermodelle verrechnen Messungen von Stationen, Satelliten, Flugzeugen und Bojen zu einem lückenlosen, weltweiten Verlauf zurück bis 1940." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datengrundlage ist die ERA5-Reanalyse: Wettermodelle verrechnen Messungen von Stationen, Satelliten, Flugzeugen und Bojen zu einem lückenlosen, weltweiten Verlauf zurück bis 1940."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The data comes from the ERA5 reanalysis: weather models combine measurements from stations, satellites, aircraft, and buoys into a gap-free, worldwide record reaching back to 1940."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veriler ERA5 yeniden analizinden gelir: hava modelleri istasyon, uydu, uçak ve şamandıra ölçümlerini 1940'a kadar uzanan kesintisiz, dünya çapında bir kayıtta birleştirir."
          }
        }
      }
    },
