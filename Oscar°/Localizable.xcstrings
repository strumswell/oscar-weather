    "AI GEFS ist ein guter Kompromiss für die nächsten ein bis zwei Wochen." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI GEFS is a good compromise for the next one to two weeks."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI GEFS, önümüzdeki bir ila iki hafta için iyi bir dengedir."
          }
        }
      }
    },
    "AIFS eignet sich gut für mittelfristige Unsicherheit, lokale Details können geglättet wirken." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AIFS is useful for medium-range uncertainty, but local details can look smoothed."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AIFS orta vadeli belirsizliği görmek için kullanışlıdır, ancak yerel ayrıntılar yumuşatılmış görünebilir."
          }
        }
      }
    },
