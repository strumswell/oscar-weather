        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oscar'da bildirimler kapalı. Mevcut konumunuz için yağmur uyarıları ve hava durumu uyarıları almak üzere bunları açın."
          }
        }
