    "Allow notifications in iOS Settings to receive rain alerts and weather alerts in Central Europe." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erlaube Mitteilungen in den iOS Einstellungen, um Regenwarnungen und Wetterwarnungen in Mitteleuropa zu erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow notifications in iOS Settings to receive rain alerts and weather alerts in Central Europe."
          }
        },
        "tr" : {
