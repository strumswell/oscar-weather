    },
    "Der Live-Regenstatus zeigt aufziehenden Regen als Live-Aktivität auf dem Sperrbildschirm und in der Dynamic Island. Er benötigt aktive Regen-Warnungen." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The live rain status shows approaching rain as a Live Activity on the Lock Screen and in the Dynamic Island. It requires rain alerts to be turned on."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Canlı yağmur durumu, yaklaşan yağmuru kilit ekranında ve Dynamic Island'da canlı aktivite olarak gösterir. Bunun için yağmur uyarılarının açık olması gerekir."
          }
        }
      }
