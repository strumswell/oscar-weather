          }
        }
      }
    },
    "Wählt für jeden Ort weltweit automatisch das beste Modell und kombiniert mehrere Wetterdienste." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählt für jeden Ort weltweit automatisch das beste Modell und kombiniert mehrere Wetterdienste."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically picks the best model for any location worldwide and combines several weather services."
