    "Turn on rain alerts or weather alerts to receive beta notifications in Central Europe. Your approximate location will be stored on an Oscar server for this." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere Regenwarnungen oder Wetterwarnungen, um Beta-Mitteilungen in Mitteleuropa zu erhalten. Dein ungefährer Standort wird dazu auf einem Oscar-Server gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turn on rain alerts or weather alerts to receive beta notifications in Central Europe. Your approximate location will be stored on an Oscar server for this."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Orta Avrupa'da beta bildirimleri almak için yağmur uyarılarını veya hava durumu uyarılarını açın. Bunun için yaklaşık konumunuz bir Oscar sunucusunda saklanacaktır."
          }
        }
      }
    },
    "Turn on rain alerts or weather alerts to receive notifications. Your approximate location will be stored on an Oscar server for this." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere Regenwarnungen oder Wetterwarnungen, um Mitteilungen zu erhalten. Dein ungefährer Standort wird dazu auf einem Oscar-Server gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turn on rain alerts or weather alerts to receive notifications. Your approximate location will be stored on an Oscar server for this."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bildirim almak için yağmur uyarılarını veya hava durumu uyarılarını açın. Bunun için yaklaşık konumunuz bir Oscar sunucusunda saklanacaktır."
          }
        }
      }
    },
