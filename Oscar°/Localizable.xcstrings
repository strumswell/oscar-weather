    "Wähle, ob die Tageswerte ersetzt oder im 24-Stunden-Bereich markiert werden." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle, ob die Tageswerte ersetzt oder im 24-Stunden-Bereich markiert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose whether daytime values replace the daily values or are marked within the 24-hour range."
          }
