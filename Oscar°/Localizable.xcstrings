    "ACCESS-G - Australian Bureau of Meteorology (BOM)" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ACCESS-G - Australian Bureau of Meteorology (BOM)"
